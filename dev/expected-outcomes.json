{
  "name": "Mock Thread Baseline Expectations",
  "description": "Sanity checks for expected outcomes on dev/mockThread.json",
  "checks": [
    {
      "id": "topic-classification",
      "label": "Topic should map to trauma_safety",
      "path": "result.summary.topic",
      "op": "eq",
      "expected": "trauma_safety"
    },
    {
      "id": "topic-risk-level",
      "label": "Thread topic risk should be critical",
      "path": "result.summary.threadTopicRisk.level",
      "op": "eq",
      "expected": "critical"
    },
    {
      "id": "risk-patterns",
      "label": "Critical overlap patterns should be detected",
      "path": "result.summary.threadTopicRisk.detectedPatternTypes",
      "op": "includesAll",
      "expected": [
        "sexual_abuse",
        "minor_sexual_abuse"
      ]
    },
    {
      "id": "overall-risk-floor",
      "label": "Overall risk should be >= 0.40",
      "path": "result.summary.overallRisk",
      "op": "gte",
      "expected": 0.4
    },
    {
      "id": "climate-supportive",
      "label": "Conversation climate should be supportive",
      "path": "result.summary.conversationClimate.label",
      "op": "eq",
      "expected": "supportive"
    },
    {
      "id": "alignment-consensus",
      "label": "Alignment should be consensus",
      "path": "result.summary.alignment.label",
      "op": "eq",
      "expected": "consensus"
    },
    {
      "id": "dominant-non-neutral",
      "label": "Dominant stance should not be neutral",
      "path": "result.summary.alignment.dominantStance",
      "op": "neq",
      "expected": "neutral"
    },
    {
      "id": "role-observer-floor",
      "label": "Observer role count should be >= 8",
      "path": "metrics.roleCounts.observer",
      "op": "gte",
      "expected": 8
    },
    {
      "id": "role-info-seeker-floor",
      "label": "Information seeker role count should be >= 8",
      "path": "metrics.roleCounts.information_seeker",
      "op": "gte",
      "expected": 8
    },
    {
      "id": "tone-suppression-floor",
      "label": "Low-confidence tone suppression should affect >= 20 comments",
      "path": "metrics.suppressedTone",
      "op": "gte",
      "expected": 20
    },
    {
      "id": "intent-suppression-floor",
      "label": "Low-confidence intent suppression should affect >= 10 comments",
      "path": "metrics.suppressedIntent",
      "op": "gte",
      "expected": 10
    }
  ],
